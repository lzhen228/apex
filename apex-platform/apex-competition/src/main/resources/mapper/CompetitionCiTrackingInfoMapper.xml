<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.harbourbiomed.apex.competition.mapper.CompetitionCiTrackingInfoMapper">

    <!-- 查询矩阵数据 -->
    <select id="queryMatrixData" resultType="com.harbourbiomed.apex.competition.vo.CellDrugVO">
        SELECT
            drug_id AS drugId,
            drug_name_en AS drugNameEn,
            drug_name_cn AS drugNameCn,
            global_highest_phase AS phase,
            global_highest_phase_score AS phaseScore,
            originator,
            moa,
            nct_id AS nctId,
            ARRAY(SELECT unnest(targets)) AS targets,
            indication_top_global_start_date AS indicationStartDate
        FROM ci_tracking_latest
        WHERE 1=1
        <if test="request.diseaseIds != null and request.diseaseIds.size() > 0">
            AND disease_id IN
            <foreach collection="request.diseaseIds" item="id" open="(" separator="," close=")">
                #{id}
            </foreach>
        </if>
        <if test="request.targets != null and request.targets.size() > 0">
            AND (
            <foreach collection="request.targets" item="target" separator=" OR ">
                #{target} = ANY(targets)
            </foreach>
            )
        </if>
        <if test="request.phases != null and request.phases.size() > 0">
            AND global_highest_phase IN
            <foreach collection="request.phases" item="phase" open="(" separator="," close=")">
                #{phase}
            </foreach>
        </if>
        <if test="request.origins != null and request.origins.size() > 0">
            AND originator IN
            <foreach collection="request.origins" item="origin" open="(" separator="," close=")">
                #{origin}
            </foreach>
        </if>
        <if test="request.moaKeywords != null and request.moaKeywords.size() > 0">
            AND (
            <foreach collection="request.moaKeywords" item="keyword" separator=" OR ">
                moa ILIKE CONCAT('%', #{keyword}, '%')
            </foreach>
            )
        </if>
        ORDER BY global_highest_phase_score DESC
    </select>

    <!-- 查询指定靶点和疾病的药物详情 -->
    <select id="queryCellDrugs" resultType="com.harbourbiomed.apex.competition.vo.CellDrugVO">
        SELECT
            drug_id AS drugId,
            drug_name_en AS drugNameEn,
            drug_name_cn AS drugNameCn,
            global_highest_phase AS phase,
            global_highest_phase_score AS phaseScore,
            originator,
            moa,
            nct_id AS nctId,
            ARRAY(SELECT unnest(targets)) AS targets,
            indication_top_global_start_date AS indicationStartDate
        FROM ci_tracking_latest
        WHERE #{target} = ANY(targets)
        AND disease_id = #{diseaseId}
        <if test="phasesList != null and phasesList.size() > 0">
            AND global_highest_phase IN
            <foreach collection="phasesList" item="phase" open="(" separator="," close=")">
                #{phase}
            </foreach>
        </if>
        ORDER BY global_highest_phase_score DESC
    </select>

    <!-- 查询靶点聚合信息 -->
    <select id="queryTargetAggregation" resultType="java.util.Map">
        SELECT
            unnest(targets) AS targetName,
            COUNT(*) AS drugCount,
            AVG(global_highest_phase_score) AS avgPhaseScore
        FROM ci_tracking_latest
        WHERE 1=1
        <if test="request.diseaseIds != null and request.diseaseIds.size() > 0">
            AND disease_id IN
            <foreach collection="request.diseaseIds" item="id" open="(" separator="," close=")">
                #{id}
            </foreach>
        </if>
        <if test="request.targets != null and request.targets.size() > 0">
            AND (
            <foreach collection="request.targets" item="target" separator=" OR ">
                #{target} = ANY(targets)
            </foreach>
            )
        </if>
        <if test="request.phases != null and request.phases.size() > 0">
            AND global_highest_phase IN
            <foreach collection="request.phases" item="phase" open="(" separator="," close=")">
                #{phase}
            </foreach>
        </if>
        <if test="request.origins != null and request.origins.size() > 0">
            AND originator IN
            <foreach collection="request.origins" item="origin" open="(" separator="," close=")">
                #{origin}
            </foreach>
        </if>
        <if test="request.moaKeywords != null and request.moaKeywords.size() > 0">
            AND (
            <foreach collection="request.moaKeywords" item="keyword" separator=" OR ">
                moa ILIKE CONCAT('%', #{keyword}, '%')
            </foreach>
            )
        </if>
        GROUP BY unnest(targets)
        ORDER BY avgPhaseScore DESC
    </select>

</mapper>
