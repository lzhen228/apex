<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.harbourbiomed.apex.datasync.mapper.SyncLogMapper">

    <!-- 根据模块查询最新的同步日志 -->
    <select id="getLatestSyncLogs" resultType="com.harbourbiomed.apex.datasync.entity.DataSyncLog">
        SELECT * FROM data_sync_log
        WHERE module = #{module}
        ORDER BY created_at DESC
        LIMIT #{limit}
    </select>

    <!-- 根据批次 ID 查询日志 -->
    <select id="getByBatchId" resultType="com.harbourbiomed.apex.datasync.entity.DataSyncLog">
        SELECT * FROM data_sync_log
        WHERE sync_batch_id = #{batchId}
        LIMIT 1
    </select>

</mapper>
